{
  "name": "sysprom",
  "version": "1.0.0",
  "description": "SysProM — System Provenance Model CLI",
  "type": "module",
  "bin": {
    "sysprom": "./dist/src/cli/index.js"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "compile": "tsc",
    "build": "pnpm typecheck && pnpm compile && tsx src/generate-schema.ts",
    "test": "tsx --test tests/*.test.ts",
    "test:coverage": "c8 --src src --exclude 'src/cli/**' --exclude 'src/generate-schema.ts' tsx --test tests/*.test.ts",
    "json2md": "tsx src/cli/index.ts json2md",
    "md2json": "tsx src/cli/index.ts md2json"
  },
  "devDependencies": {
    "@types/node": "25.5.0",
    "c8": "11.0.0",
    "tsx": "4.19.4",
    "typescript": "5.9.3",
    "zod": "4.3.6"
  }
}
