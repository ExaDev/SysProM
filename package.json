{
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "pnpm typecheck && tsx src/generate-schema.ts",
    "test": "tsx --test tests/*.test.ts",
    "test:coverage": "c8 --src src --exclude 'src/cli/**' --exclude 'src/generate-schema.ts' tsx --test tests/*.test.ts",
    "json2md": "tsx src/cli/json2md.ts",
    "md2json": "tsx src/cli/md2json.ts"
  },
  "devDependencies": {
    "@types/node": "25.5.0",
    "c8": "11.0.0",
    "tsx": "4.19.4",
    "typescript": "5.9.3",
    "zod": "4.3.6"
  }
}
