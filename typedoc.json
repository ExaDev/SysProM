{
  "$schema": "https://typedoc.org/schema.json",
  "entryPoints": ["./src/index.ts"],
  "out": "docs/api",
  "plugin": ["typedoc-plugin-markdown"],
  "name": "SysProM",
  "readme": "none",
  "excludePrivate": true,
  "excludeInternal": true,
  "expandObjects": false,
  "expandParameters": false,
  "typeDeclarationFormat": "table",
  "validation": {
    "notExported": true,
    "invalidLink": true,
    "notDocumented": false
  }
}
