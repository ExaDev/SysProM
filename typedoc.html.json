{
  "$schema": "https://typedoc.org/schema.json",
  "entryPoints": ["./src"],
  "entryPointStrategy": "expand",
  "exclude": ["**/cli/**", "**/generate-schema.ts", "**/index.ts"],
  "out": "site",
  "plugin": ["typedoc-plugin-zod"],
  "name": "SysProM",
  "readme": "README.md",
  "projectDocuments": ["docs/cli/README.md"],
  "excludePrivate": true,
  "excludeInternal": true,
  "validation": {
    "notExported": true,
    "invalidLink": true,
    "notDocumented": false
  }
}
