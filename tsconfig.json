{
	"compilerOptions": {
		"target": "ES2022",
		"module": "nodenext",
		"moduleResolution": "nodenext",
		"strict": true,
		"esModuleInterop": true,
		"resolveJsonModule": true,
		"skipLibCheck": true,
		"outDir": "dist",
		"rootDir": ".",
		"declaration": true
	},
	"types": ["node"],
	"include": ["src/**/*.ts", "tests/**/*.ts"]
}
